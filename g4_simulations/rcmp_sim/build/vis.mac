/run/initialize

/DetSys/world/material Vacuum
#/DetSys/det/addGriffinForward 8
/DetSys/det/addRCMP

/tracking/storeTrajectory 1
/vis/open OGL
#/vis/open OGLIQt
/vis/drawVolume
/vis/viewer/set/autoRefresh true
/vis/scene/add/trajectories smooth
/vis/scene/add/axes 0 0 0 10 cm
/vis/viewer/set/targetPoint 0 0 0 m
/vis/viewer/set/style surface
/vis/scene/endOfEventAction accumulate 10000
#/DetSys/gun/position 0.0 0.0 0.0 cm
/gun/particle alpha
/DetSys/gun/efficiencyEnergy 2. MeV
#/run/beamOn 1000
